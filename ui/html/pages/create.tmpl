{{define "title"}}Create a New Post{{end}}

{{define "main"}}
<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Create a New Post</h1>

        <form action="/post/create" method="POST" x-data="{ titleChars: 0, contentChars: 0 }">
            <!-- Title -->
            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                {{with .Form.FieldErrors.Title}}
                    <p class="text-red-500 text-sm mb-1">{{.}}</p>
                {{end}}
                <input type="text" name="title" value="{{.Form.Title}}"
                    x-on:input="titleChars = $el.value.length"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"
                    placeholder="What's your question or topic?">
                <span class="text-xs mt-1 block" :class="titleChars > 100 ? 'text-red-500' : 'text-gray-400'" x-text="titleChars + '/100'"></span>
            </div>

            <!-- Content -->
            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-700 mb-1">Content</label>
                {{with .Form.FieldErrors.Content}}
                    <p class="text-red-500 text-sm mb-1">{{.}}</p>
                {{end}}
                <textarea name="content" rows="5"
                    x-on:input="contentChars = $el.value.length"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none resize-none transition"
                    placeholder="Describe your question or share your knowledge...">{{.Form.Content}}</textarea>
                <span class="text-xs mt-1 block" :class="contentChars > 250 ? 'text-red-500' : 'text-gray-400'" x-text="contentChars + '/250'"></span>
            </div>

            <!-- Categories as chips -->
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Categories</label>
                <div class="flex flex-wrap gap-2">
                    {{if .Categories}}
                    {{range .Categories}}
                    <label class="cursor-pointer">
                        <input type="checkbox" name="categoryIDs[]" value="{{.ID}}" class="peer hidden">
                        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600
                            peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600 transition">
                            {{.Name}}
                        </span>
                    </label>
                    {{end}}
                    {{end}}
                </div>
            </div>

            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition">
                Publish Post
            </button>
        </form>
    </div>
</div>
{{end}}