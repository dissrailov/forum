{{define "title"}}Sign up{{end}}

{{define "main"}}
<div class="max-w-md mx-auto mt-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <div class="text-center mb-6">
            <div class="w-14 h-14 bg-gradient-to-br from-emerald-400 to-blue-500 rounded-2xl flex items-center justify-center mx-auto mb-3">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Create an account</h1>
            <p class="text-gray-500 text-sm mt-1">Join the FitTalk community</p>
        </div>

        <form action="/user/signup" method="POST" novalidate>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                {{with .Form.FieldErrors.name}}
                    <p class="text-red-500 text-sm mb-1">{{.}}</p>
                {{end}}
                <input type="text" name="name" value="{{.Form.Name}}"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"
                    placeholder="Your name">
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                {{with .Form.FieldErrors.email}}
                    <p class="text-red-500 text-sm mb-1">{{.}}</p>
                {{end}}
                <input type="email" name="email" value="{{.Form.Email}}"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"
                    placeholder="you@example.com">
            </div>

            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                {{with .Form.FieldErrors.password}}
                    <p class="text-red-500 text-sm mb-1">{{.}}</p>
                {{end}}
                <input type="password" name="password"
                    class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none transition"
                    placeholder="Min. 8 characters">
            </div>

            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition">
                Sign up
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-5">
            Already have an account? <a href="/user/login" class="text-emerald-600 hover:text-emerald-700 font-medium">Log in</a>
        </p>
    </div>
</div>
{{end}}